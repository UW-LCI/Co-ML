    "[help text] add diverse images" : {
      "comment" : "Help text.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ لإنتاج أفضل نموذج، أضف **مجموعة متنوعة** من الصور إلى كل تسمية."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Hosh tofoni liholsochi, addi **tak ohmi** chi intokchi apliha."
          }
        },
        "chr-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ ᎾᏍᎩ ᎣᏍᏓ ᏧᏁᎦ, ᎬᏩᏚ ᏧᎾᎵᏏᏙᏗᏱ **ᏧᎾᏬᏂᏍᎩ** ᎯᎠ ᎾᏍᎩ ᏧᏅᏏᏓᏍᏗ ᎤᏩᏒᎯ."
          }
        },
        "cic-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Apelahe issoba palilish isht ia, nanta pala chim anukfillit hattak chatuk lopulli."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Um das beste Modell zu erstellen, füge jedem Label einen **unterschiedlichen Satz von Bildern** hinzu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ To produce the best model, add a **diverse set** of images to each label."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Para producir el mejor modelo, agrega un **conjunto diverso** de imágenes a cada etiqueta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Pour produire le meilleur modèle, ajoutez un **ensemble varié** d’images à chaque étiquette."
          }
        },
        "ga" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Chun an tsamhail is fearr a tháirgeadh, cuir **sraith éagsúil** íomhánna le gach lipéad."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ सबसे अच्छा model बनाने के लिए, हर एक label में images का **diverse set** जोड़ें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Untuk menghasilkan model terbaik, tambahkan **beragam rangkaian** gambar ke setiap label."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Per creare un modello ottimale, aggiungi una **serie diversificata** di immagini a ogni etichetta."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ 최상의 모델을 생성하려면 각 레이블에 **다양한 이미지 세트**를 추가하십시오."
          }
        },
        "mi-NZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Kia pai rawa ai te tauira, tāpiri he huinga **kanorau** whakaahua ki ia tapanga."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Para produzir o melhor modelo, adicione um **conjunto diversificado** de imagens a cada etiqueta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Чтобы создать лучшую модель, добавьте к каждой метке **набор разных** изображений."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ சிறந்த மாதிரியை உருவாக்க, ஒவ்வொரு லேபிளிலும் **பல்வேறு படங்களின் தொகுப்பைச்** சேர்க்கவும்."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Щоб створити найкращу модель, додайте до кожної мітки **неоднорідний набір** зображень."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ Để tạo ra mô hình tốt nhất, hãy thêm một **tập hợp hình ảnh đa dạng** vào mỗi nhãn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "☝️ 为训练出性能卓越的模型，请为每个标签添加**种类丰富、形式多样**的图像。"
          }
        }
      }
    },
    "[help text] collect training data" : {
      "comment" : "Help text.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 ثم **اجمع بيانات التدريب** عن طريق إضافة الصور إلى كل تسمية."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 Tohbi **oktokchi holitoba** chi liholsochi apliha."
          }
        },
        "chr-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 ᎿᎭᏉ ᎢᏤᏔᏛ **ᎠᎵᏏᏙᎲᏍᎦ** ᎦᏥᏩᏛᏍᏗᎭ ᎾᏍᎩᏯᎢ."
          }
        },
        "cic-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 Kanimachi hattak lopullichi **palilish**."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 Dann **sammle Trainingsdaten**, indem du jedem Label Bilder hinzufügst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 Then **collect training data** by adding images to each label."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 Luego, **recopila datos de entrenamiento** agregando imágenes a cada etiqueta."
