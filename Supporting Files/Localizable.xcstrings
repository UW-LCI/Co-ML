        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passez en revue les modifications apportées depuis le dernier entraînement de votre modèle. Pour plus d’informations, accédez à Préparer les données."
          }
        },
        "ga" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Athbhreithnigh na hathruithe ó rinne tú an uair dheireanach a thraenáil tú do shamhail. Téigh go dtí Ullmhaigh Sonraí le haghaidh tuilleadh sonraí."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पिछली बार जब आपने अपने model को train किया था, तब से बदलावों का review करें। ज़्यादा details के लिए Prepare Data पर जाएँ।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tinjau perubahan sejak terakhir kali Anda melatih model. Buka Prepare Data (Siapkan Data) untuk detail selengkapnya."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rivedi le modifiche apportate dall’ultimo addestramento del modello. Vai a Prepara dati per maggiori dettagli."
          }
