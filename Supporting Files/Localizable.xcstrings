    "Review changes since the last time you trained" : {
      "comment" : "Informative subtitle.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "راجع التغييرات منذ آخر مرة قمت فيها بتدريب النموذج. انتقل إلى \"تحضير البيانات\" للحصول على مزيد من التفاصيل."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chishno chokka kanimachi tok vt nah himona shikenanchit oke. Na yukpa palilish data apisa chim anumpa momen hattakvt."
          }
        },
        "chr-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ᎢᏤᎢ ᏂᎦᏓ ᏱᎠᎵᏏᏙᎸᎭ ᎾᏍᎩ ᏄᏍᏛᎢ. Ꮀ ᎠᏏ ᎡᏥᏰᎵᎴᎯᏍᏗ ᎤᏟ ᎠᎴ ᎪᏪᎵ."
          }
        },
        "cic-US" : {
          "stringUnit" : {
            "state" : "translated",
