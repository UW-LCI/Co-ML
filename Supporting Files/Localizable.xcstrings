    "This project will be removed from your gallery [etc]" : {
      "comment" : "Informative alert text.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ستتم إزالة هذا المشروع من معرض الصور الخاص بك. ستظل إمكانية الوصول متاحة لمالك المشروع والمشاركين الآخرين."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aiokchalinchi galla isht anumpa apvlomo oke tok. Aiokchalinchit achvffa nana kanohmit aiokpvlatok oke."
          }
        },
        "chr-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ᎯᎠ ᏄᏍᏛᎢ ᏫᏚᏍᏗᎧᏁᎵ ᏦᎢᏧᏈ ᎦᎪᏢᏛᎢ. ᎾᏍᎩ ᎤᎾᏤᎵᎪᎯ ᎠᎴ ᏅᏩᏙᎯᏯᏛ ᏩᏚᏩᏒᎯ."
          }
        },
        "cic-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aiokchalinchi galla isht anumpa apvlomo oke tok. Aiokchalinchit achvffa nana kanohmit aiokpvlatok oke."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Projekt wird aus deiner Galerie entfernt. Der:die Projekteigentümer:in und andere Teilnehmende haben weiterhin Zugriff."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This project will be removed from your gallery. The project owner and other participants will still have access."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este proyecto se eliminará de tu galería. El propietario del proyecto y los demás participantes seguirán teniendo acceso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce projet sera supprimé de votre galerie. Le ou la propriétaire du projet et les autres personnes participantes y auront toujours accès."
          }
        },
        "ga" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bainfear an tionscadal seo as do ghailearaí. Beidh rochtain ag úinéir an tionscadail agus ag rannpháirtithe eile fós."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस project को आपकी gallery से हटा दिया जाएगा। Project owner और दूसरे participants के पास अभी भी access होगा।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proyek ini akan dihapus dari galeri Anda. Pemilik proyek dan peserta lainnya masih dapat mengaksesnya."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo progetto verrà rimosso dalla galleria. Chi ha la proprietà del progetto e le altre persone che vi partecipano potranno comunque accedere."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 프로젝트가 갤러리에서 제거됩니다. 프로젝트 소유자 및 기타 참가자는 여전히 접근할 수 있습니다."
          }
        },
        "mi-NZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ka tangohia tēnei kaupapa i tō taiwhanga. Kei te pupuri tonu te rangatira o te kaupapa me ētahi atu kaiuru i te uru."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este projeto será removido da galeria. O proprietário do projeto e outros participantes ainda terão acesso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот проект будет удалён из вашей галереи. У создателя проекта и других участников по-прежнему будет доступ."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "இந்தத் திட்டம் உங்கள் கேலரியில் இருந்து அகற்றப்படும். திட்ட உரிமையாளர் மற்றும் பிற பங்கேற்பாளர்களுக்கு இன்னும் அணுகல் இருக்கும்."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цей проєкт буде видалено з вашої галереї. Організатор проєкту й інші учасники і надалі матимуть до нього доступ."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dự án này sẽ bị xóa khỏi thư viện của bạn. Người sở hữu dự án và những người tham gia khác sẽ vẫn có quyền truy cập."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这个项目将从你的图库中被移除。项目所有者和其他参与者仍可访问这个项目。"
          }
        }
      }
    },
    "To capture images go to settings etc" : {
      "comment" : "Informative alert message.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لالتقاط صور جديدة للتدريب واختبار الصور باستخدام الكاميرا، انتقل إلى \"الإعدادات\" وقم بتمكين الوصول إلى الكاميرا."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apelahe patola yakni kanimvt hattak piha tok keyu, na yukpa apisa patola apakfobvt hosh isht alhtosbi."
          }
        },
        "chr-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ᎢᏗᎦᏟᎶᏍᏙᏗᎭ ᏗᎾᏬᏂᏍᎩ ᎩᎶ ᏧᎵᏏᏙᎲᏍᎬ, ᎡᏍᎦ ᏄᏍᏗᏳᎯ."
          }
        },
        "cic-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apelahe patola yakni kanimvt hattak piha tok keyu, na yukpa apisa patola apakfobvt hosh isht alhtosbi."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um neue Trainings- und Testbilder mit der Kamera aufzunehmen, gehe zu „Einstellungen\" und aktiviere den Kamerazugriff."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To capture new training and test images with the camera, go to Settings and enable camera access."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para capturar nuevas imágenes de entrenamiento y prueba con la cámara, ve a Configuración y activa el acceso a la cámara."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour collecter de nouvelles images d’entraînement et de test avec la caméra, accédez à Réglages et activez l’accès à la caméra."
          }
        },
        "ga" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chun íomhánna nua oiliúna agus tástála a ghabháil leis an gceamara, gabh chuig Socruithe agus cumasaigh rochtain ceamara."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Camera से नई training और test images capture करने के लिए, Settings पर जाएँ और camera access चालू करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Untuk menangkap gambar tes dan latihan baru dengan kamera, buka Pengaturan, lalu aktifkan akses kamera."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per acquisire nuove immagini di addestramento e test con la fotocamera, vai in Impostazioni e abilita l’accesso alla fotocamera."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카메라로 새로운 학습 이미지와 테스트 이미지를 캡처하려면 설정으로 이동하여 카메라 액세스를 활성화하십시오."
          }
        },
        "mi-NZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kia hopu whakaahua whakangungu me whakamātau hōu mā te kāmera, haere ki Tautuhinga ka whakaae ki te uru kāmera."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para capturar novos treinamentos e testar imagens com a câmera, acesse Ajustes e ative o acesso à câmera."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтобы снимать новые обучающие и тестовые изображения с помощью камеры, перейдите в меню «Настройки» и предоставьте доступ к камере."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "கேமரா மூலம் புதிய பயிற்சி மற்றும் பரிசோதனைப் படங்களைப் படம்பிடிக்க, அமைப்புகளுக்குச் சென்று கேமரா அணுகலை இயக்கவும்."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Щоб зробити нові навчальні й тестові знімки за допомогою камери, перейдіть до меню «Параметри» й увімкніть доступ до неї."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Để chụp hình ảnh đào tạo và thử nghiệm mới bằng camera, hãy vào phần Cài đặt và bật quyền truy cập camera."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要使用相机拍摄新的训练图像和测试图像，请前往“设置”并启用相机访问权限。"
          }
        }
      }
    },
