    "Please connect to the Internet to share this project." : {
      "comment" : "Alert message.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرجى الاتصال بالإنترنت لمشاركة هذا المشروع."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "translated",
