          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überprüfe die Änderungen seit dem letzten Trainieren deines Modells. Gehe zu „Daten vorbereiten“, um weitere Informationen zu erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Review changes since the last time you trained your model. Go to Prepare Data for more detail."
