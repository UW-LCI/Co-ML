    "delete label cautionary alert message “%@”" : {
      "comment" : "Cautionary alert message, explaining the consequences of deleting a whole label.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "إن حذف \"%@\" يعني أنك سوف تحذف أيضًا جميع الصور المرتبطة بهذه التسمية. هذا الإجراء لا يمكن التراجع عنه."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Otok nitakli ishli chi “%@”, chi hosh tohbi chi liholsochi chi holitoba chi tuk ish illaboli. Chi illaboli hosh yakni tukmohpi."
          }
        },
        "chr-US" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ᎾᏍᎩ “%@”, ᏫᏥᏍᏗᎧᏅᏗ ᎾᏍᏉ ᏂᏥᏍᏗᎧᏁᎸ ᏄᏍᏛᎢ ᎾᎿᎭᏂᎬᏁᎸᎢ. ᎯᎠ ᏝᏳᏃ ᏱᎬᏩᏛᏟᏴᏗ."
          }
        },
        "cic-US" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Himmi, nanta ist at balichi hattak “%@” himmi oke. Aiokpalichi himmi osh toksali."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Durch Löschen von „%@“ löschst du auch alle Bilder, die mit diesem Label verknüpft sind. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By deleting “%@”, you’ll also delete all images associated with this label. This action cannot be undone."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Al eliminar “%@”, también eliminarás todas las imágenes asociadas con esta etiqueta. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "En supprimant « %@ », vous supprimerez également toutes les images associées à cette étiquette. Cette action est irréversible."
          }
        },
        "ga" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trí “%@” a scriosadh, scriosfaidh tú gach íomhá a bhaineann leis an lipéad seo freisin. Ní féidir an gníomh seo a chealú."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” को हटाकर, आप इस label से जुड़ी सभी images भी हटा देंगे। इस action को पहले जैसा नहीं किया जा सकता।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dengan menghapus “%@”, Anda juga akan menghapus semua gambar yang terkait dengan label ini. Tindakan ini tidak dapat diurungkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Eliminando “%@” verranno eliminate anche tutte le immagini associate a questa etichetta. Questa azione non può essere annullata."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "\"%@\"을(를) 삭제하면 이 레이블에 연결된 모든 이미지도 삭제됩니다. 이 작업은 실행 취소할 수 없습니다."
          }
        },
        "mi-NZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mā te muku i “%@” ka mukua hoki ngā whakaahua katoa e pā ana ki tēnei tapanga."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ao apagar “%@”, você também apagará todas as imagens associadas a essa etiqueta. Esta ação não pode ser desfeita."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Удалив «%@», вы также стираете все изображения, связанные с этой меткой. Это действие невозможно отменить."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "“%@” ஐ நீக்குவதன் மூலம், இந்த லேபிளுடன் தொடர்புடைய அனைத்து படங்களையும் நீக்குவீர்கள். இந்தச் செயலைச் செயல்தவிர்க்க முடியாது."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "У разі видалення «%@» ви також видаляєте всі зображення, пов’язані із цією міткою. Цю дію неможливо скасувати."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bằng cách xóa \"%@\", bạn cũng sẽ xóa tất cả các hình ảnh liên kết với nhãn này. Không thể hoàn tác hành động này."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "删除“%@”后，与这个标签关联的所有图像也将被一并删除。这项操作无法撤销。"
          }
        }
      }
    },
