        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 Kemudian, **kumpulkan data latihan** dengan menambahkan gambar ke setiap label."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 Successivamente, **raccogli i dati di addestramento** aggiungendo immagini a ogni etichetta."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 그런 다음 각 레이블에 이미지를 추가하여 **교육 데이터를 수집**합니다."
          }
        },
        "mi-NZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📸 Kātahi ka **kohikohi raraunga whakangungu** mā te tāpiri whakaahua ki ia tapanga."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
