    "Add at least 2 labels etc" : {
      "comment" : "Help text for training page.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف تسميتين على الأقل مع 3 صور لكل تسمية لتدريب النموذج الخاص بك. انتقل إلى \"تحضير البيانات\" لإضافة المزيد من البيانات."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atuk tohbi 2 labili chi 3 intokchi chi labili bvnchi tohmi tak ish akit chi intokchi. Ossimma atuk Kanohit Iyanohma chi takli bvnchi tak hosh ohmi."
          }
        },
        "chr-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ᎠᏂᏔᎵ ᏫᏚᏩᏛᎲᎭ ᎢᎦᏓ ᏧᏅᏏᏓᏍᏗ ᎦᎵᏉᎩ ᏗᎾᏬᏂᏍᎩ ᏫᏚᏩᏛᎲᎭ ᎾᏍᎩᏯ ᎢᏣᏛᏅᎢᏍᏓᏁᏗ. Ꮀ ᎠᏏ ᎡᏥᏰᎵᎴᎯᏍᏗ ᎤᏟ ᎠᎴ ᎪᏪᎵ."
          }
        },
        "cic-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nanta pelakoshi 2 chim anumpa toksvli chim 3 anukfilli issoba kanimahchi. Achukma chim anumpa nanvtta lopulli tuk keyu na Yupka apisa."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füge mindestens 2 Labels mit 3 Bildern pro Label hinzu, um dein Modell zu trainieren. Gehe zu „Daten vorbereiten“, um weitere Daten hinzuzufügen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add at least 2 labels with 3 images per label to train your model. Go to Prepare Data to add more data."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agrega al menos 2 etiquetas con 3 imágenes por etiqueta para entrenar tu modelo. Ve a Preparar datos para agregar más datos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez au moins deux étiquettes comprenant chacune trois images pour entraîner votre modèle. Accédez à Préparer les données pour ajouter plus de données."
          }
        },
        "ga" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuir 2 lipéad ar a laghad leis le 3 íomhá in aghaidh an lipéid chun do shamhail a thraenáil. Gabh chuig Ullmhaigh Sonraí chun tuilleadh sonraí a chur leis."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने model को train करने के लिए हर एक label पर तीन images वाले कम से कम दो labels जोड़ें। ज़्यादा data जोड़ने के लिए Prepare Data पर जाएँ।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tambahkan setidaknya 2 label dengan 3 gambar per label untuk melatih model Anda. Buka Prepare Data (Siapkan Data) untuk menambahkan lebih banyak data."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi almeno 2 etichette con 3 immagini ciascuna per addestrare il modello. Vai a Prepara dati per aggiungere altri dati."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모델을 학습시키려면 2개 이상의 레이블과 레이블당 3개의 이미지를 추가하십시오. 데이터를 더 추가하려면 '데이터 준비'로 이동하십시오."
          }
        },
        "mi-NZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tāpiri kia 2 neke atu ngā tapanga me ngā whakaahua e 3 mō ia tapanga kia taea ai te whakangungu i tō tauira."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicione pelo menos 2 etiquetas com 3 imagens por etiqueta para treinar seu modelo. Acesse Prepare Data para adicionar mais dados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавьте не менее 2 меток с 3 изображениями к каждой метке, чтобы обучить свою модель. Перейдите в раздел «Подготовить данные», чтобы добавить дополнительные данные."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "உங்கள் மாதிரிக்குப் பயிற்சியளிக்க, ஒரு லேபிளுக்கு 3 படங்களுடன் குறைந்தது 2 லேபிள்களைச் சேர்க்கவும். கூடுதல் தரவைச் சேர்க்க, தரவைத் தயார் செய் என்பதற்குச் செல்லவும்."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Щоб навчити модель, додайте принаймні дві мітки (по три зображення на кожну мітку). Перейдіть до розділу «Підготувати дані», щоб додати більше даних."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thêm ít nhất 2 nhãn, mỗi nhãn 3 hình ảnh, để đào tạo mô hình. Vào phần Chuẩn bị dữ liệu để thêm dữ liệu khác."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "至少添加 2 个标签，且每个标签需包含 3 张图像，方可开始训练模型。前往“准备数据”以添加更多数据。"
          }
        }
      }
    },
