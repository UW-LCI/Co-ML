    "delete projects confirmation message" : {
      "comment" : "Alert message.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم أيضًا حذف جميع البيانات الموجودة في مشاريعك. لا يمكنك التراجع عن هذا الإجراء."
          }
        },
        "cho-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aiokchalinchi moma chim anumpa pelakoshi himmi oke. Aiokpalichi himmit osh toksali."
          }
        },
        "chr-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ᏂᎦᏓ ᎠᏩᏛᏍᏗᎭ ᏄᏍᏛᎢ ᎾᏍᏉ ᏓᏳᏍᏗᎧᏁᎵ. ᎯᎠ ᏝᏃ ᏱᏣᏛᏟᏴᏗ."
          }
        },
        "cic-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chi hosh illaboli chi holitoba chi chikba hosh holhito. Yakni yakni ish illaboli."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Daten in deinen Projekten werden ebenfalls gelöscht. You cannot undo this action."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All the data in your project(s) will also be deleted. You cannot undo this action."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "También se eliminarán todos los datos de tus proyectos. No puedes deshacer esta acción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes les données de vos projets seront également supprimées. You cannot undo this action."
          }
        },
        "ga" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lena chois sin, scriosfar na sonraí go léir i do thionscada(i)l. Ní féidir leis an ngníomh seo a chealú."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके projects का सारा data भी हटा दिया जाएगा। You cannot undo this action."
          }
        },
        "id" : {
